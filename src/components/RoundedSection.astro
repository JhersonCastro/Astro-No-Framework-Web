---
export interface Props {
  imagenSrc?: string;
  textos?: string[];
}
import { Image } from "astro:assets";

import FrameMiku  from "../assets/FrameMiku.png";
const { 
  imagenSrc = FrameMiku,
  textos = ["Nivel: Universidad", "Institución: Universidad del cauca", "Años: 2023-2026"]
} = Astro.props;
---
<section id="RotationSection">
  <table>
    <caption>La animacion sin gsap nope, asi que la tabla:D</caption>
    <thead>
      <tr>
        <th>Nivel</th>
        <th>Institución</th>
        <th>Años</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Universidad</td>
        <td>Universidad del Cauca</td>
        <td>2023-2026</td>
      </tr>
    </tbody>
  </table>
</section>


