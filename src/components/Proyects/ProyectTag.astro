---
const { Title, Description, Status, ImgSrc } = Astro.props;
---

<div class="project-card">

  <div class="project-image">

    <img 
      src={ImgSrc}
      alt={Title}
      class="project-img"
      loading="lazy"
    />

    <span class="project-status">
      {Status}
    </span>

  </div>

  <div class="project-content">

    <h2 class="project-title">
      {Title}
    </h2>

    <p class="project-description">
      {Description}
    </p>

    <slot />

  </div>

</div>
