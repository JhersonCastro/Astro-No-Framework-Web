---
import { Image } from "astro:assets";
import musica from "../../assets/musica.png";
---

<section id="musica-section" class="section">

  <div class="container">
    
    <div class="header">
      <h2 class="title">
        Musica
      </h2>
    </div>

    <div class="layout">
      
      <div class="image-side">
        <div class="image-wrapper">
          
          <div class="card">

            <Image 
              src={musica} 
              alt="Persona escuchando música con auriculares" 
              class="section-img"
              loading="lazy"
            />

            <div class="note note1">♪</div>
            <div class="note note2">♫</div>

          </div>

        </div>
      </div>

      <div class="text-side">
        
        <p class="music-text">
          Me gusta escuchar desde pop hasta música antigua como 
          <span class="music-highlight">
            The Beatles, Michael Jackson o Queen
          </span>. 
          La música me relaja y me inspira.
        </p>

      </div>

    </div>

  </div>

</section>

<style>

.music-text{
  font-size:1.6rem;
  line-height:1.6;
  color:#f3e8ff;
}

.music-highlight{
  font-weight:600;
  background:linear-gradient(90deg,#fde047,#f472b6);
  -webkit-background-clip:text;
  color:transparent;
}

.note{
  position:absolute;
  opacity:0.5;
}

.note1{
  top:-20px;
  right:-10px;
  font-size:2.5rem;
  animation:bounce 2s infinite;
}

.note2{
  bottom:-15px;
  left:-15px;
  font-size:2rem;
  animation:pulse 2s infinite;
}

@keyframes bounce{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}

@keyframes pulse{
  0%,100%{opacity:0.4}
  50%{opacity:1}
}

</style>